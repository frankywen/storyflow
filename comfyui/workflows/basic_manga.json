{
  "name": "basic_manga_generation",
  "description": "基础漫画风格图片生成工作流",
  "version": "1.0.0",
  "workflow": {
    "1": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 0,
        "steps": 20,
        "cfg": 7,
        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": 1,
        "model": ["4", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["5", 0]
      }
    },
    "2": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["1", 0],
        "vae": ["4", 2]
      }
    },
    "3": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "manga",
        "images": ["2", 0]
      }
    },
    "4": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "sdxl_base_1.0.safetensors"
      }
    },
    "5": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": 1024,
        "height": 1024,
        "batch_size": 1
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{positive_prompt}}",
        "clip": ["4", 1]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "low quality, blurry, distorted, ugly, bad anatomy, worst quality",
        "clip": ["4", 1]
      }
    }
  },
  "variables": {
    "positive_prompt": {
      "type": "string",
      "default": "manga style, 1girl, beautiful face, detailed background",
      "description": "Positive prompt for image generation"
    }
  }
}