# StoryFlow Backend Configuration Example
# Copy this file to .env and fill in your values

# ============================================
# Server Configuration
# ============================================
PORT=8080
GIN_MODE=debug

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=storyflow
DB_SSLMODE=disable

# ============================================
# LLM Configuration
# ============================================
# Supported providers: claude, alibaba, volcengine
LLM_PROVIDER=alibaba
LLM_API_KEY=your-llm-api-key
LLM_MODEL=qwen3.5-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Alibaba/Qwen
# LLM_PROVIDER=alibaba
# LLM_API_KEY=sk-xxx
# LLM_MODEL=qwen3.5-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Volcengine/Doubao
# LLM_PROVIDER=volcengine
# LLM_API_KEY=xxx
# LLM_MODEL=doubao-pro-32k
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Claude (Anthropic)
# LLM_PROVIDER=claude
# LLM_API_KEY=sk-ant-xxx
# LLM_MODEL=claude-sonnet-4-20250514

# ============================================
# Image Generation Configuration
# ============================================
# Supported providers: comfyui, volcengine, alibaba
IMAGE_PROVIDER=volcengine
IMAGE_API_KEY=your-image-api-key
IMAGE_MODEL=doubao-seedream-3-0-t2i-250415
IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ComfyUI (Local GPU)
# IMAGE_PROVIDER=comfyui
# IMAGE_BASE_URL=http://localhost:8188

# Volcengine/Doubao (火山引擎/豆包)
# IMAGE_PROVIDER=volcengine
# IMAGE_API_KEY=xxx
# IMAGE_MODEL=doubao-seedream-3-0-t2i-250415
# IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Alibaba/Wanxiang (阿里云/通义万相)
# IMAGE_PROVIDER=alibaba
# IMAGE_API_KEY=sk-xxx
# IMAGE_MODEL=wanx-v1
# IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ============================================
# Video Generation Configuration
# ============================================
# Supported providers: kling, runway, volcengine
VIDEO_PROVIDER=volcengine
VIDEO_API_KEY=your-video-api-key
VIDEO_MODEL=doubao-seedance-1-0-pro-250528
VIDEO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
VIDEO_DURATION=5                    # Default video duration in seconds (5 or 10 for Kling, 5 for Volcengine)

# Kling (可灵) - Recommended, cheaper option
# VIDEO_PROVIDER=kling
# VIDEO_API_KEY=xxx
# VIDEO_BASE_URL=https://api.klingai.com/v1
# VIDEO_DURATION=10                  # Kling supports 5 or 10 seconds

# Runway Gen-3
# VIDEO_PROVIDER=runway
# VIDEO_API_KEY=xxx
# VIDEO_BASE_URL=https://api.runwayml.com/v1

# Volcengine/Doubao (火山引擎/豆包) - 图生视频
# VIDEO_PROVIDER=volcengine
# VIDEO_API_KEY=xxx
# VIDEO_MODEL=doubao-seedance-1-0-pro-250528
# VIDEO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
# VIDEO_DURATION=5                   # Volcengine default 5 seconds
# Note: 需要在火山引擎控制台开通视频生成服务

# Video Merge Configuration (uses ffmpeg)
# VIDEO_OUTPUT_DIR=./uploads/videos

# ============================================
# Storage Configuration
# ============================================
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# ============================================
# Optional: TTS Configuration (Phase 2)
# ============================================
# AZURE_TTS_KEY=
# AZURE_TTS_REGION=eastasia

# ============================================
# Admin Seed Configuration
# ============================================
# Initial admin user is created automatically if no admin exists
# Change these values after first login!
ADMIN_EMAIL=admin@storyflow.local
ADMIN_PASSWORD=admin123456
ADMIN_NAME=Admin

# ============================================
# Authentication Configuration
# ============================================
JWT_ACCESS_SECRET=storyflow-access-secret-key-change-this
JWT_REFRESH_SECRET=storyflow-refresh-secret-key-change-this
ENCRYPTION_SECRET=storyflow-encryption-key-32-bytes-long