# Server
PORT=8080
GIN_MODE=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=storyflow
DB_SSLMODE=disable

# ===========================================
# LLM Provider Configuration
# ===========================================
# Supported providers: claude, volcengine (doubao), alibaba (qwen)
LLM_PROVIDER=claude
LLM_API_KEY=your-api-key
LLM_MODEL=claude-sonnet-4-20250514
# LLM_BASE_URL=  # Optional, for custom endpoints

# Legacy config (still supported)
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# VolcEngine/Doubao LLM
# LLM_PROVIDER=volcengine
# LLM_API_KEY=your-volcengine-api-key
# LLM_MODEL=doubao-pro-32k
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Alibaba/Qwen LLM
# LLM_PROVIDER=alibaba
# LLM_API_KEY=your-dashscope-api-key
# LLM_MODEL=qwen-max
# LLM_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ===========================================
# Image Generation Provider Configuration
# ===========================================
# Supported providers: comfyui, volcengine (doubao), alibaba (wanxiang)
IMAGE_PROVIDER=comfyui
IMAGE_API_KEY=your-api-key
# IMAGE_BASE_URL=  # Optional
# IMAGE_MODEL=     # Optional

# ComfyUI (local GPU)
COMFYUI_URL=http://localhost:8188

# VolcEngine/Doubao Image Generation
# IMAGE_PROVIDER=volcengine
# IMAGE_API_KEY=your-volcengine-api-key
# IMAGE_MODEL=doubao-seedream-3-0-t2i-250415
# IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Alibaba Wanxiang Image Generation
# IMAGE_PROVIDER=alibaba
# IMAGE_API_KEY=your-dashscope-api-key
# IMAGE_MODEL=wanx-v1
# IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# Image Storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Video Generation (Phase 2)
# KLING_API_KEY=
# RUNWAY_API_KEY=

# TTS (Phase 2)
# AZURE_TTS_KEY=
# AZURE_TTS_REGION=eastasia